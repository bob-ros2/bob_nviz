# bob_nviz Environment Configuration Template
# Copy this to .env and set your values

# ==============================================================================
# TWITCH STREAMING SETTINGS (CRITICAL)
# ==============================================================================
# Your secret Twitch Stream Key (from Dashboard > Settings > Stream)
TWITCH_STREAM_KEY=live_000000000_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twitch Ingest Server (choose the one closest to you)
# RTMP URL list: https://help.twitch.tv/s/article/guide-to-broadcast-health-and-logging#ingestlist
INGEST_SERVER=rtmp://live-fra.twitch.tv/app/


# ==============================================================================
# NVIZ RENDERER SETTINGS
# ==============================================================================
# Video dimensions
NVIZ_WIDTH=854
NVIZ_HEIGHT=480

# Target framerate
NVIZ_FPS=30

# Path to the raw BGRA video pipe
NVIZ_FIFO_PATH=/tmp/nano_fifo


# ==============================================================================
# AUDIO PIPELINE SETTINGS (bob_audio)
# ==============================================================================
# Input pipe where external audio is fed into the mixer
AUDIO_PIPE=/tmp/audio_pipe

# Master pipe where the mixed audio stream is sent to FFmpeg
AUDIO_MASTER_PATH=/tmp/audio_master_pipe


# ==============================================================================
# ROS 2 SETTINGS
# ==============================================================================
# Path to your workspace setup file
# ROS_SETUP_PATH=/ros2_ws/install/setup.bash
